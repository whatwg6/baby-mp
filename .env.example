# Runtime
APP_ENV=local
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=3000
CORS_ORIGINS=http://localhost:10086

# PostgreSQL (local Docker only)
POSTGRES_DB=baby_mp
POSTGRES_USER=baby_mp
POSTGRES_PASSWORD=baby-mp-local-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://baby_mp:baby-mp-local-password@localhost:5432/baby_mp?schema=public

# Session extension points (mock login is implemented in M2, never enabled by default)
JWT_ACCESS_SECRET=replace-for-local-development-only
JWT_REFRESH_SECRET=replace-for-local-development-only
MOCK_AUTH_ENABLED=false

# Private S3-compatible storage (local MinIO only)
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=baby-mp-local
S3_ACCESS_KEY=baby-mp-local
S3_SECRET_KEY=baby-mp-local-password
S3_FORCE_PATH_STYLE=true
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Optional Taro compile-time override. For WeChat device testing, use the
# development machine's LAN address instead of localhost.
TARO_APP_API_BASE_URL=http://localhost:3000
