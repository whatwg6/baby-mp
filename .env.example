# Runtime
APP_ENV=local
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=3000
TRUST_PROXY=false
JSON_BODY_LIMIT_BYTES=262144
SWAGGER_ENABLED=true
INTERNAL_MONITORING_TOKEN=
BUSINESS_TIME_ZONE=Asia/Shanghai
CORS_ORIGINS=http://localhost:10086

# PostgreSQL (local Docker only)
POSTGRES_DB=baby_mp
POSTGRES_USER=baby_mp
POSTGRES_PASSWORD=baby-mp-local-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://baby_mp:baby-mp-local-password@localhost:5432/baby_mp?schema=public

# Session extension points (mock login is implemented in M2, never enabled by default)
JWT_ACCESS_SECRET=replace-for-local-development-only
JWT_REFRESH_SECRET=replace-for-local-development-only
MOCK_AUTH_ENABLED=false

# WeChat mini program login (AppID is public configuration; never commit AppSecret)
WECHAT_APP_ID=wx433aecb90d44e9fe
WECHAT_APP_SECRET=
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session

# Private S3-compatible storage (local MinIO only)
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=baby-mp-local
S3_ACCESS_KEY=baby-mp-local
S3_SECRET_KEY=baby-mp-local-password
S3_FORCE_PATH_STYLE=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_INVITE_MAX=30
RATE_LIMIT_UPLOAD_MAX=60
EXPORT_WORKER_MAX_ITERATION_SECONDS=7200
MEDIA_CLEANUP_INTERVAL_SECONDS=3600
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Optional Taro compile-time override. For WeChat device testing, use the
# development machine's LAN address instead of localhost.
TARO_APP_API_BASE_URL=http://localhost:3000

# Operations scripts use libpq/AWS credential environment variables so secrets
# never need to appear in command arguments. Keep real values in a secret store.
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=baby_mp
# PGUSER=baby_mp
# PGPASSWORD=inject-from-secret-store
# BACKUP_DIR=./backups/postgresql
# BACKUP_AGE_RECIPIENT=age1-public-recipient-for-staging-or-production
# AWS_ACCESS_KEY_ID=inject-from-secret-store
# AWS_SECRET_ACCESS_KEY=inject-from-secret-store
