{
  "name": "baby-mp",
  "version": "0.1.0",
  "private": true,
  "description": "Baby MP local-first monorepo",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.12.0 <23",
    "pnpm": ">=10.33.4 <11"
  },
  "scripts": {
    "contracts:build": "pnpm --filter @baby-mp/contracts build",
    "dev": "pnpm --filter @baby-mp/contracts build && pnpm --parallel --filter @baby-mp/api --filter @baby-mp/client run dev",
    "dev:api": "pnpm --filter @baby-mp/contracts build && pnpm --filter @baby-mp/api dev",
    "dev:client": "pnpm --filter @baby-mp/contracts build && pnpm --filter @baby-mp/client dev",
    "dev:weapp": "pnpm --filter @baby-mp/contracts build && pnpm --filter @baby-mp/client dev:weapp",
    "build": "pnpm -r --if-present build",
    "lint": "eslint . --max-warnings=0",
    "pretypecheck": "pnpm contracts:build",
    "typecheck": "pnpm -r --if-present typecheck",
    "pretest": "pnpm contracts:build",
    "test": "pnpm -r --if-present test",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm verify:traceability && pnpm build && pnpm verify:runtime-preflight",
    "verify:traceability": "node scripts/verify-test-traceability.mjs --require-covered",
    "verify:runtime-preflight": "scripts/verify-runtime-preflight.sh",
    "verify:m2:api": "scripts/verify-m2-api.sh",
    "verify:m3:api": "scripts/verify-m3-api.sh",
    "verify:m4:api": "scripts/verify-m4-api.sh",
    "verify:m5:api": "scripts/verify-m5-api.sh",
    "verify:m6:api": "scripts/verify-m6-api.sh",
    "verify:m7:api": "scripts/verify-m7-api.sh",
    "verify:artifact-budgets": "scripts/verify-artifact-budget.sh",
    "verify:artifacts": "pnpm verify:artifact-budgets && pnpm --filter @baby-mp/client check:release-artifacts",
    "release:manifest": "pnpm --filter @baby-mp/client create:release-manifest",
    "release:manifest:verify": "pnpm --filter @baby-mp/client verify:release-manifest",
    "db:generate": "pnpm --filter @baby-mp/api prisma:generate",
    "db:migrate": "pnpm --filter @baby-mp/api prisma:migrate",
    "db:deploy": "pnpm --filter @baby-mp/api prisma:deploy",
    "openapi:generate": "pnpm --filter @baby-mp/api openapi:generate",
    "media:cleanup": "pnpm --filter @baby-mp/api media:cleanup",
    "exports:worker": "pnpm --filter @baby-mp/api exports:worker",
    "exports:cleanup": "pnpm --filter @baby-mp/api exports:cleanup",
    "data-rights:transition": "pnpm --filter @baby-mp/api data-rights:transition"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "eslint": "9.31.0",
    "globals": "16.3.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.37.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "normalize-url@2.0.1": "patches/normalize-url@2.0.1.patch"
    },
    "overrides": {
      "esbuild": "0.25.12",
      "fast-uri": "3.1.4",
      "swiper": "12.1.2",
      "uuid": "11.1.1",
      "webpack": "5.104.1",
      "webpack-dev-server": "5.2.6",
      "@tarojs/webpack5-runner@4.1.5>webpack-dev-server": "4.15.2"
    }
  }
}
