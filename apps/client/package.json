{
  "name": "@baby-mp/client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "taro build --type h5 --watch",
    "dev:h5": "taro build --type h5 --watch",
    "dev:weapp": "taro build --type weapp --watch",
    "build": "pnpm run build:h5 && pnpm run build:weapp",
    "build:h5": "taro build --type h5",
    "build:weapp": "taro build --type weapp",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@baby-mp/contracts": "workspace:*",
    "@tarojs/components": "4.1.5",
    "@tarojs/react": "4.1.5",
    "@tarojs/runtime": "4.1.5",
    "@tarojs/shared": "4.1.5",
    "@tarojs/taro": "4.1.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-react": "7.29.7",
    "@pmmmwh/react-refresh-webpack-plugin": "0.5.17",
    "@tarojs/cli": "4.1.5",
    "@tarojs/plugin-framework-react": "4.1.5",
    "@tarojs/plugin-platform-h5": "4.1.5",
    "@tarojs/plugin-platform-weapp": "4.1.5",
    "@tarojs/webpack5-runner": "4.1.5",
    "@types/node": "22.15.32",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "babel-preset-taro": "4.1.5",
    "less": "4.4.1",
    "react-refresh": "0.14.2",
    "sass": "1.89.2",
    "vitest": "3.2.4"
  }
}
