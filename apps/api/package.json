{
  "name": "@baby-mp/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint src test --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "openapi:generate": "node --import tsx src/openapi/generate-openapi.ts",
    "start": "node dist/main.js",
    "media:cleanup": "node dist/media/cleanup-media.js",
    "media:cleanup:scheduler": "node dist/media/run-media-cleanup-scheduler.js",
    "exports:worker": "node dist/exports/run-export-worker.js",
    "exports:cleanup": "node dist/exports/run-export-worker.js --cleanup",
    "data-rights:transition": "node dist/data-rights/run-data-rights-transition.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@aws-sdk/s3-request-presigner": "^3.1088.0",
    "@baby-mp/contracts": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.6",
    "@prisma/client": "6.11.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "prisma": "6.11.1",
    "sharp": "^0.35.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.10",
    "@nestjs/testing": "11.1.28",
    "@types/express": "5.0.3",
    "@types/node": "22.16.4",
    "@types/supertest": "6.0.3",
    "supertest": "7.1.4",
    "tsx": "4.20.3",
    "vitest": "3.2.4"
  }
}
