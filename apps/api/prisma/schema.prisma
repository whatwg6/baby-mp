generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformType {
  wechat_mini
  alipay_mini
  douyin_mini
  h5

  @@map("platform_type")
}

enum UserStatus {
  active
  disabled
  deleted

  @@map("user_status")
}

enum BabyGender {
  male
  female
  unspecified

  @@map("baby_gender")
}

enum MemberRole {
  admin
  editor
  viewer

  @@map("member_role")
}

enum MemberStatus {
  active
  removed

  @@map("member_status")
}

enum RecordType {
  note
  measurement
  milestone

  @@map("record_type")
}

enum MediaStatus {
  pending
  uploaded
  ready
  failed
  deleted

  @@map("media_status")
}

enum MediaPurpose {
  record_image
  export_archive

  @@map("media_purpose")
}

enum InviteStatus {
  pending
  accepted
  revoked
  expired

  @@map("invite_status")
}

enum ExportStatus {
  pending
  processing
  completed
  failed
  expired

  @@map("export_status")
}

enum DataRightsRequestType {
  account_deletion
  data_access
  correction

  @@map("data_rights_request_type")
}

enum DataRightsRequestStatus {
  pending
  processing
  completed
  rejected
  cancelled

  @@map("data_rights_request_status")
}

model User {
  id           String             @id @default(uuid()) @db.Uuid
  displayName  String?            @map("display_name") @db.VarChar(80)
  avatarMediaId String?           @map("avatar_media_id") @db.Uuid
  status       UserStatus         @default(active)
  lastLoginAt  DateTime?          @map("last_login_at") @db.Timestamptz(3)
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt    DateTime?          @map("deleted_at") @db.Timestamptz(3)
  avatarMedia  Media?             @relation("UserAvatar", fields: [avatarMediaId], references: [id], onDelete: SetNull)
  identities   PlatformIdentity[]
  sessions     RefreshSession[]
  memberships  BabyMember[]       @relation("MemberUser")
  createdBabies Baby[]             @relation("BabyCreator")
  invitedMemberships BabyMember[]  @relation("MemberInviter")
  removedMemberships BabyMember[]  @relation("MemberRemover")
  idempotencyKeys IdempotencyKey[]
  ownedMedia    Media[]            @relation("MediaOwner")
  createdRecords Record[]          @relation("RecordCreator")
  updatedRecords Record[]          @relation("RecordUpdater")
  deletedRecords Record[]          @relation("RecordDeleter")
  createdInvites FamilyInvite[]    @relation("InviteCreator")
  acceptedInvites FamilyInvite[]   @relation("InviteAcceptor")
  auditLogs AuditLog[]              @relation("AuditActor")
  requestedExports ExportJob[]      @relation("ExportRequester")
  dataRightsRequests DataRightsRequest[]

  @@map("users")
}

model PlatformIdentity {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  platform     PlatformType
  appId        String       @map("app_id") @db.VarChar(128)
  subject      String       @db.VarChar(255)
  unionSubject String?      @map("union_subject") @db.VarChar(255)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([platform, appId, subject])
  @@index([userId])
  @@map("platform_identities")
}

model RefreshSession {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  familyId            String    @map("family_id") @db.Uuid
  tokenHash           String    @unique @map("token_hash") @db.Char(64)
  platform             PlatformType
  expiresAt            DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt            DateTime? @map("revoked_at") @db.Timestamptz(3)
  revokeReason         String?   @map("revoke_reason") @db.VarChar(40)
  replacedBySessionId  String?   @unique @map("replaced_by_session_id") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy           RefreshSession? @relation("SessionRotation", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  replaces             RefreshSession? @relation("SessionRotation")

  @@index([userId, revokedAt])
  @@index([familyId])
  @@map("refresh_sessions")
}

model Baby {
  id              String       @id @default(uuid()) @db.Uuid
  name            String       @db.VarChar(40)
  gender          BabyGender
  birthDate       DateTime     @map("birth_date") @db.Date
  birthTime       DateTime?    @map("birth_time") @db.Time(0)
  birthHeightCm   Decimal?     @map("birth_height_cm") @db.Decimal(5, 2)
  birthWeightKg   Decimal?     @map("birth_weight_kg") @db.Decimal(6, 3)
  avatarMediaId   String?      @map("avatar_media_id") @db.Uuid
  createdBy       String       @map("created_by") @db.Uuid
  version         Int          @default(1)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz(3)
  creator         User         @relation("BabyCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  members         BabyMember[]
  media           Media[]
  records         Record[]
  invites         FamilyInvite[]
  auditLogs       AuditLog[]
  exportJobs      ExportJob[]
  dataRightsRequests DataRightsRequest[]
  avatarMedia     Media?        @relation("BabyAvatar", fields: [avatarMediaId], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@map("babies")
}

model Media {
  id              String      @id @default(uuid()) @db.Uuid
  ownerUserId     String      @map("owner_user_id") @db.Uuid
  babyId          String      @map("baby_id") @db.Uuid
  storageProvider String      @default("s3") @map("storage_provider") @db.VarChar(32)
  bucket          String      @db.VarChar(128)
  objectKey       String      @unique @map("object_key") @db.VarChar(512)
  uploadObjectKey String?     @unique @map("upload_object_key") @db.VarChar(512)
  mimeType        String      @map("mime_type") @db.VarChar(100)
  sizeBytes       BigInt      @map("size_bytes")
  width           Int?
  height          Int?
  sha256          String?     @db.Char(64)
  status          MediaStatus @default(pending)
  purpose         MediaPurpose @default(record_image)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  readyAt         DateTime?   @map("ready_at") @db.Timestamptz(3)
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamptz(3)
  purgedAt        DateTime?   @map("purged_at") @db.Timestamptz(3)
  owner           User        @relation("MediaOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  baby            Baby        @relation(fields: [babyId], references: [id], onDelete: Cascade)
  records         RecordMedia[]
  userAvatars     User[]      @relation("UserAvatar")
  babyAvatars     Baby[]      @relation("BabyAvatar")
  exportResults   ExportJob[] @relation("ExportResult")

  @@index([babyId, status])
  @@index([ownerUserId, status, createdAt])
  @@map("media")
}

model Record {
  id          String             @id @default(uuid()) @db.Uuid
  babyId      String             @map("baby_id") @db.Uuid
  type        RecordType
  title       String?            @db.VarChar(120)
  content     String?
  occurredAt  DateTime           @map("occurred_at") @db.Timestamptz(3)
  createdBy   String             @map("created_by") @db.Uuid
  updatedBy   String             @map("updated_by") @db.Uuid
  metadata    Json               @default("{}")
  version     Int                @default(1)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt   DateTime?          @map("deleted_at") @db.Timestamptz(3)
  deletedBy   String?            @map("deleted_by") @db.Uuid
  baby        Baby               @relation(fields: [babyId], references: [id], onDelete: Cascade)
  creator     User               @relation("RecordCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  updater     User               @relation("RecordUpdater", fields: [updatedBy], references: [id], onDelete: Restrict)
  deleter     User?              @relation("RecordDeleter", fields: [deletedBy], references: [id], onDelete: Restrict)
  measurement MeasurementRecord?
  media       RecordMedia[]

  @@index([babyId, occurredAt(sort: Desc), id(sort: Desc)])
  @@index([babyId, type, occurredAt(sort: Desc), id(sort: Desc)])
  @@index([createdBy, createdAt(sort: Desc)])
  @@map("records")
}

model MeasurementRecord {
  recordId  String   @id @map("record_id") @db.Uuid
  heightCm  Decimal? @map("height_cm") @db.Decimal(5, 2)
  weightKg  Decimal? @map("weight_kg") @db.Decimal(6, 3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  record    Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@map("measurement_records")
}

model RecordMedia {
  recordId  String   @map("record_id") @db.Uuid
  mediaId   String   @map("media_id") @db.Uuid
  sortOrder Int      @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  record    Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@id([recordId, mediaId])
  @@unique([recordId, sortOrder])
  @@index([mediaId])
  @@map("record_media")
}

model BabyMember {
  id          String       @id @default(uuid()) @db.Uuid
  babyId      String       @map("baby_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  role        MemberRole
  status      MemberStatus @default(active)
  joinedAt    DateTime     @default(now()) @map("joined_at") @db.Timestamptz(3)
  invitedBy   String?      @map("invited_by") @db.Uuid
  removedAt   DateTime?    @map("removed_at") @db.Timestamptz(3)
  removedBy   String?      @map("removed_by") @db.Uuid
  version     Int          @default(1)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  baby        Baby         @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user        User         @relation("MemberUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter     User?        @relation("MemberInviter", fields: [invitedBy], references: [id], onDelete: SetNull)
  remover     User?        @relation("MemberRemover", fields: [removedBy], references: [id], onDelete: SetNull)

  @@unique([babyId, userId])
  @@index([userId, status])
  @@index([babyId, status])
  @@map("baby_members")
}

model IdempotencyKey {
  userId       String   @map("user_id") @db.Uuid
  key          String   @db.VarChar(128)
  operation    String   @db.VarChar(80)
  requestHash  String   @map("request_hash") @db.Char(64)
  responseCode Int?     @map("response_code")
  responseBody Json?    @map("response_body")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, operation, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model FamilyInvite {
  id         String       @id @default(uuid()) @db.Uuid
  babyId     String       @map("baby_id") @db.Uuid
  role       MemberRole
  tokenHash  String       @unique @map("token_hash") @db.Char(64)
  status     InviteStatus @default(pending)
  expiresAt  DateTime     @map("expires_at") @db.Timestamptz(3)
  createdBy  String       @map("created_by") @db.Uuid
  acceptedBy String?      @map("accepted_by") @db.Uuid
  acceptedAt DateTime?    @map("accepted_at") @db.Timestamptz(3)
  revokedAt  DateTime?    @map("revoked_at") @db.Timestamptz(3)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  baby       Baby         @relation(fields: [babyId], references: [id], onDelete: Cascade)
  creator    User         @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  acceptor   User?        @relation("InviteAcceptor", fields: [acceptedBy], references: [id], onDelete: SetNull)

  @@index([babyId, status, createdAt(sort: Desc)])
  @@index([expiresAt, status])
  @@map("family_invites")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  babyId      String?  @map("baby_id") @db.Uuid
  action      String   @db.VarChar(80)
  resourceType String  @map("resource_type") @db.VarChar(50)
  resourceId  String?  @map("resource_id") @db.Uuid
  requestId   String?  @map("request_id") @db.VarChar(64)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  baby        Baby?    @relation(fields: [babyId], references: [id], onDelete: SetNull)

  @@index([babyId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model ExportJob {
  id             String       @id @default(uuid()) @db.Uuid
  babyId         String       @map("baby_id") @db.Uuid
  requestedBy    String       @map("requested_by") @db.Uuid
  status         ExportStatus @default(pending)
  scope          Json
  resultMediaId  String?      @unique @map("result_media_id") @db.Uuid
  errorCode      String?      @map("error_code") @db.VarChar(64)
  attemptCount   Int          @default(0) @map("attempt_count")
  nextAttemptAt  DateTime     @default(now()) @map("next_attempt_at") @db.Timestamptz(3)
  workerLeaseId  String?      @map("worker_lease_id") @db.Uuid
  leaseExpiresAt DateTime?    @map("lease_expires_at") @db.Timestamptz(3)
  startedAt      DateTime?    @map("started_at") @db.Timestamptz(3)
  completedAt    DateTime?    @map("completed_at") @db.Timestamptz(3)
  expiresAt      DateTime?    @map("expires_at") @db.Timestamptz(3)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  baby           Baby         @relation(fields: [babyId], references: [id], onDelete: Cascade)
  requester      User         @relation("ExportRequester", fields: [requestedBy], references: [id], onDelete: Restrict)
  resultMedia    Media?       @relation("ExportResult", fields: [resultMediaId], references: [id], onDelete: SetNull)

  @@index([babyId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([status, nextAttemptAt])
  @@index([requestedBy, createdAt(sort: Desc)])
  @@map("export_jobs")
}

model DataRightsRequest {
  id                String                  @id @default(uuid()) @db.Uuid
  requesterUserId   String                  @map("requester_user_id") @db.Uuid
  babyId            String?                 @map("baby_id") @db.Uuid
  type              DataRightsRequestType
  status            DataRightsRequestStatus @default(pending)
  activeRequestKey  String?                 @unique @map("active_request_key") @db.VarChar(160)
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)
  resolvedAt        DateTime?               @map("resolved_at") @db.Timestamptz(3)
  requester         User                    @relation(fields: [requesterUserId], references: [id], onDelete: Restrict)
  baby              Baby?                   @relation(fields: [babyId], references: [id], onDelete: SetNull)

  @@index([requesterUserId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("data_rights_requests")
}
